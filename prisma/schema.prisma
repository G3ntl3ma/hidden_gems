datasource db {
  provider = "sqlite"
  url      = "file:dev.db"
}

generator client {
  provider             = "prisma-client-py"
  interface            = "sync"
  recursive_type_depth = 5
  output               = "./generated"
}

model Game {
  id                   Int     @id
  name                 String
  required_age         Int     @default(0)
  is_free              Boolean @default(false)
  detailed_description String?
  about_the_game       String?
  short_description    String?
  supported_languages  String?
  header_image         String?
  developers           String?
  publishers           String?
  windows              Boolean @default(false)
  mac                  Boolean @default(false)
  linux                Boolean @default(false)
  metacritic           Int?
  release_date         DateTime?
  coming_soon          Boolean @default(false)
  owners_min           Int     @default(0)
  owners_max           Int     @default(0)
  average_2weeks       Int     @default(0)
  average_forever      Int     @default(0)

  // Aggregate review summary (optional, from query_summary)
  reviewNumReviews    Int?
  reviewScore         Int?
  reviewScoreDesc     String?
  reviewTotalPositive Int?
  reviewTotalNegative Int?
  reviewTotalReviews  Int?

  // Relations
  gameDevelopers GameDeveloper[]
  gamePublishers GamePublisher[]
  categories     GameCategory[]
  genres         GameGenre[]
  reviews        Review[]
}

model Category {
  id   Int    @id
  name String

  games GameCategory[]
}

model GameCategory {
  gameId     Int
  categoryId Int

  game     Game     @relation(fields: [gameId], references: [id])
  category Category @relation(fields: [categoryId], references: [id])

  @@id([gameId, categoryId])
}

model Genre {
  id   Int    @id
  name String

  games GameGenre[]
}

model GameGenre {
  gameId Int
  genreId Int

  game  Game  @relation(fields: [gameId], references: [id])
  genre Genre @relation(fields: [genreId], references: [id])

  @@id([gameId, genreId])
}

model Developer {
  name                   String @id
  amount_games_published Int    @default(0)

  games GameDeveloper[]
}

model Publisher {
  name                   String @id
  amount_games_published Int    @default(0)

  games GamePublisher[]
}

model GameDeveloper {
  gameId        Int
  developerName String

  game      Game      @relation(fields: [gameId], references: [id])
  developer Developer @relation(fields: [developerName], references: [name])

  @@id([gameId, developerName])
}

model GamePublisher {
  gameId        Int
  publisherName String

  game      Game      @relation(fields: [gameId], references: [id])
  publisher Publisher @relation(fields: [publisherName], references: [name])

  @@id([gameId, publisherName])
}

model Review {
  id                       String   @id
  gameId                   Int
  authorSteamId            String?
  authorPlaytimeForever    Int      @default(0)
  authorPlaytimeAtReview   Int      @default(0)
  authorLastPlayed         DateTime?
  language                 String?
  review                   String?
  votedUp                  Boolean  @default(false)
  votesUp                  Int      @default(0)
  votesFunny               Int      @default(0)
  weightedVoteScore        Float?
  writtenDuringEarlyAccess Boolean  @default(false)

  game Game @relation(fields: [gameId], references: [id])

  timestampCreated DateTime?
  timestampUpdated DateTime?

  @@index([gameId])
  @@index([authorSteamId])
}